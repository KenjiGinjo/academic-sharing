generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  AUTHOR
}

enum PostType {
  BLOG
  TUTORIAL
}

enum TutorialLevel {
  Beginner
  Intermediate
  Advanced
}

enum PublicationType {
  JOURNAL
  CONFERENCE
  PREPRINT
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(AUTHOR)
  active       Boolean  @default(true)
  personId     String?  @unique
  person       Person?  @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Person {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  role           String
  bio            String
  about          String?  @db.Text
  initials       String
  avatarUrl      String?
  sortOrder      Int      @default(0)
  github         String?
  website        String?
  x              String?
  emailPublic    String?
  googleScholar  String?
  cvUrl          String?
  profileEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?
  posts          Post[]
  interests      PersonInterest[]
  publications   PersonPublication[]
  competitions   PersonCompetition[]
  applications   PersonApplication[]
  patents        PersonPatent[]
}

model PersonInterest {
  id        String @id @default(cuid())
  personId  String
  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  label     String
  sortOrder Int    @default(0)

  @@index([personId, sortOrder])
}

model PersonPublication {
  id        String          @id @default(cuid())
  personId  String
  person    Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  title     String
  authors   String
  venue     String
  year      Int?
  type      PublicationType @default(OTHER)
  url       String?
  doi       String?
  highlight Boolean         @default(false)
  sortOrder Int             @default(0)

  @@index([personId, type, sortOrder])
}

model PersonCompetition {
  id          String  @id @default(cuid())
  personId    String
  person      Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  name        String
  award       String?
  year        Int?
  description String?
  url         String?
  sortOrder   Int     @default(0)

  @@index([personId, sortOrder])
}

model PersonApplication {
  id             String  @id @default(cuid())
  personId       String
  person         Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  name           String
  kind           String?
  summary        String
  url            String?
  imageUrl       String?
  note           String?
  updatedAtLabel String?
  sortOrder      Int     @default(0)

  @@index([personId, sortOrder])
}

model PersonPatent {
  id          String  @id @default(cuid())
  personId    String
  person      Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  title       String
  status      String?
  number      String?
  year        Int?
  description String?
  url         String?
  sortOrder   Int     @default(0)

  @@index([personId, sortOrder])
}

model Post {
  id          String            @id @default(cuid())
  type        PostType
  slug        String            @unique
  title       String
  excerpt     String
  content     String            @default("") @db.Text
  level       TutorialLevel?
  tags        String[]          @default([])
  featured    Boolean           @default(false)
  published   Boolean           @default(false)
  publishedAt DateTime?
  authorId    String?
  author      Person?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  chapters    TutorialChapter[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([type, published, publishedAt])
  @@index([authorId])
  @@index([featured, published, publishedAt])
}

model TutorialChapter {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  content   String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, slug])
  @@index([postId, sortOrder])
}
